{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "pageBundle": false,
      "previewPath": null,
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "Layout",
          "name": "layout",
          "type": "string",
          "default": "post"
        },
        {
          "title": "Weight",
          "name": "weight",
          "type": "number",
          "default": 1
        },
        {
          "title": "Tiny Post",
          "name": "tiny",
          "type": "boolean",
          "default": true
        }
      ]
    }
  ],
  "frontMatter.framework.id": "jekyll",
  "frontMatter.content.publicFolder": "assets",
  "frontMatter.content.pageFolders": [
    {
      "title": "posts",
      "path": "[[workspace]]/_posts"
    }
  ],
